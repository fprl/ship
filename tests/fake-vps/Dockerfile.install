FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update \
  && apt-get install -y --no-install-recommends \
    bash \
    ca-certificates \
    curl \
    git \
    openssh-server \
    rsync \
    sqlite3 \
    sudo \
  && rm -rf /var/lib/apt/lists/*

RUN mkdir -p /run/sshd /root/.ssh /run/ship-fresh-host /etc/caddy/conf.d /etc/ufw /etc/default \
  && chmod 700 /root/.ssh \
  && useradd --system --home-dir /var/lib/caddy --shell /usr/sbin/nologin --create-home caddy

# Seed the standard Ubuntu UFW config files. fake-install-apt-get
# only records the `apt install -y ufw` call; the real apt would drop
# these. The provisioner's `podman ufw rules` op reads before.rules
# and rewrites the forward policy in default/ufw, so without them it
# would error out with "remote file does not exist" on a fresh
# fake-install run.
RUN printf '%s\n' \
    '#' \
    '# rules.before' \
    '#' \
    '# Rules that should be run before the ufw command line added rules. Custom' \
    '# rules should be added to one of these chains:' \
    '#   ufw-before-input' \
    '#   ufw-before-output' \
    '#   ufw-before-forward' \
    '#' \
    '' \
    '# Don'\''t delete these required lines, otherwise there will be errors' \
    '*filter' \
    ':ufw-before-input - [0:0]' \
    ':ufw-before-output - [0:0]' \
    ':ufw-before-forward - [0:0]' \
    ':ufw-not-local - [0:0]' \
    '# End required lines' \
    '' \
    '# allow all on loopback' \
    '-A ufw-before-input -i lo -j ACCEPT' \
    '-A ufw-before-output -o lo -j ACCEPT' \
    '' \
    'COMMIT' \
    > /etc/ufw/before.rules \
 && chmod 0640 /etc/ufw/before.rules \
 && printf '%s\n' \
    'IPV6=yes' \
    'DEFAULT_INPUT_POLICY="DROP"' \
    'DEFAULT_OUTPUT_POLICY="ACCEPT"' \
    'DEFAULT_FORWARD_POLICY="DROP"' \
    > /etc/default/ufw

COPY .fake-vps-bin/ship-linux-amd64 /usr/local/bin/ship
COPY tests/fake-vps/fake-caddy /usr/local/bin/caddy
COPY tests/fake-vps/fake-install-apt-get /usr/local/bin/apt-get
COPY tests/fake-vps/fake-install-curl /usr/local/bin/curl
COPY tests/fake-vps/fake-install-dpkg-query /usr/local/bin/dpkg-query
COPY tests/fake-vps/fake-install-gpg /usr/local/bin/gpg
COPY tests/fake-vps/fake-install-localectl /usr/local/bin/localectl
COPY tests/fake-vps/fake-install-systemctl /usr/local/bin/systemctl
COPY tests/fake-vps/fake-install-timedatectl /usr/local/bin/timedatectl
COPY tests/fake-vps/fake-install-ufw /usr/local/bin/ufw
# fake-podman stands in for the real binary because fake-apt-get does
# not actually install packages — without this shim the provisioner's
# `podman network exists ingress` op (ADR-0005 §14 / ADR-0006 Cut 2)
# fails with "executable not found in $PATH".
COPY tests/fake-vps/fake-podman /usr/local/bin/podman

RUN chmod 0755 \
    /usr/local/bin/ship \
    /usr/local/bin/caddy \
    /usr/local/bin/apt-get \
    /usr/local/bin/curl \
    /usr/local/bin/dpkg-query \
    /usr/local/bin/gpg \
    /usr/local/bin/localectl \
    /usr/local/bin/systemctl \
    /usr/local/bin/timedatectl \
    /usr/local/bin/ufw \
    /usr/local/bin/podman

EXPOSE 22

CMD ["/usr/sbin/sshd", "-D", "-e"]
