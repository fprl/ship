#!/usr/bin/env bash
# Test stand-in for `podman`. Records state under /run/fake-podman so
# tests can introspect what the helper asked for, and exposes just
# enough surface for the container-deploy lifecycle in
# cmd/helper/app_apply.go to run end-to-end without a real container
# engine.
#
# Every container started via `podman run` gets a local HTTP listener
# on a free port (recorded under containers/<name>.port). For the
# Caddy image specifically, fake-podman launches a tiny Python proxy
# that reads /etc/caddy/conf.d/*.caddy fragments and routes requests
# by Host header to the matching app container's local listener — so
# the smoke can curl through the real Caddy-shaped ingress path
# (ADR-0006 Cut 2) instead of having to address app containers
# directly.
set -euo pipefail

state_dir="${SHIP_FAKE_PODMAN_STATE:-/run/fake-podman}"
mkdir -p "$state_dir/networks" "$state_dir/containers" "$state_dir/images" "$state_dir/listeners"
chmod -R 1777 "$state_dir" 2>/dev/null || true

image_safe_name() {
  local ref="${1#localhost/}"
  printf '%s' "$ref" | tr '/:' '__'
}

image_id_of_safe() {
  local safe="$1"
  local image_path="$state_dir/images/$safe"
  # Content ids are cached beside the record; computed once per image
  # lifetime so hot paths never re-hash the whole store.
  if [[ -f "$image_path.id" ]]; then
    cat "$image_path.id"
    return 0
  fi
  local hash_path="$image_path"
  if [[ -f "$image_path.labels" ]]; then
    hash_path="$image_path.labels"
  fi
  if [[ ! -f "$hash_path" ]]; then
    echo "fake podman: no such image: $safe" >&2
    return 1
  fi
  local id
  id="sha256:$(sha256sum "$hash_path" | awk '{print $1}')"
  # Best-effort cache: images/ is sticky and multi-writer, so another
  # user's stale cache file must never turn into a hard failure here.
  { printf '%s\n' "$id" > "$image_path.id"; } 2>/dev/null || true
  printf '%s\n' "$id"
}

resolve_image_ref() {
  local ref="$1"
  local safe image_path image_id wanted
  local -a matches=()

  if [[ "$ref" =~ ^sha256:[0-9a-fA-F]{64}$ ]]; then
    wanted="${ref#sha256:}"
    wanted="$(printf '%s' "$wanted" | tr '[:upper:]' '[:lower:]')"
  elif [[ "$ref" =~ ^[0-9a-fA-F]{12,64}$ ]]; then
    wanted="$(printf '%s' "$ref" | tr '[:upper:]' '[:lower:]')"
  else
    safe="$(image_safe_name "$ref")"
    if [[ -f "$state_dir/images/$safe" ]]; then
      printf '%s\n' "$safe"
      return 0
    fi
    echo "fake podman: no such image: $ref" >&2
    return 1
  fi

  for image_path in "$state_dir"/images/*; do
    [[ -f "$image_path" && "$image_path" != *.labels && "$image_path" != *.id && "$image_path" != *.ref ]] || continue
    safe="$(basename "$image_path")"
    image_id="$(image_id_of_safe "$safe")" || return 1
    image_id="${image_id#sha256:}"
    if [[ "$image_id" == "$wanted"* ]]; then
      matches+=("$safe:$image_id")
    fi
  done

  if [[ ${#matches[@]} -eq 0 ]]; then
    echo "fake podman: no such image: $ref" >&2
    return 1
  fi

  local -a distinct_ids=()
  local match match_id found
  for match in "${matches[@]}"; do
    match_id="${match#*:}"
    found=0
    for image_id in "${distinct_ids[@]:-}"; do
      if [[ "$image_id" == "$match_id" ]]; then
        found=1
        break
      fi
    done
    [[ "$found" == 1 ]] || distinct_ids+=("$match_id")
  done
  if [[ ${#distinct_ids[@]} -gt 1 ]]; then
    echo "fake podman: image reference is ambiguous: $ref" >&2
    return 1
  fi
  printf '%s\n' "${matches[0]%%:*}"
}

run_with_env() {
  if [[ ${#run_env[@]} -gt 0 ]]; then
    env "${run_env[@]}" "$@"
  else
    "$@"
  fi
}

log_path="$state_dir/commands.log"
printf '%s\n' "podman $*" >> "$log_path"

verb="${1:-}"
shift || true

case "$verb" in
  network)
    sub="${1:-}"
    name="${2:-}"
    case "$sub" in
      exists)
        if [[ -f "$state_dir/networks/$name" ]]; then
          exit 0
        fi
        exit 1
        ;;
      create)
        : > "$state_dir/networks/$name"
        printf '%s\n' "$name"
        exit 0
        ;;
      rm)
        rm -f "$state_dir/networks/$name"
