    # Supports `podman ps -a [--filter label=K=V ...] --format json`.
    # Returns the fields containerEntry in cmd/helper/app_status.go
    # cares about: Names, State, Status, Image, Labels.
    fmt=""
    declare -a filters=()
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --format)
          fmt="$2"; shift 2 ;;
        --filter)
          filters+=("$2"); shift 2 ;;
        -a)
          shift ;;
        *)
          shift ;;
      esac
    done

    if [[ "$fmt" != "json" ]]; then
      echo "fake podman: unsupported ps format: $fmt" >&2
      exit 1
    fi

    # Emit JSON for every container whose labels match every
    # `label=K=V` filter. Python keeps the JSON shaping honest.
    python3 - "$state_dir" "${filters[@]}" <<'PY'
