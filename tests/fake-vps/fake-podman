import glob
import hashlib
import os
import sys

state_dir = sys.argv[1]
refs = sys.argv[2:]
images = {}
by_id = {}
for image_path in glob.glob(os.path.join(state_dir, "images", "*")):
    if image_path.endswith((".labels", ".id", ".ref")) or not os.path.isfile(image_path):
        continue
    safe = os.path.basename(image_path)
    id_path = image_path + ".id"
    if os.path.isfile(id_path):
        with open(id_path) as f:
            image_id = f.read().strip().removeprefix("sha256:")
    else:
        labels_path = image_path + ".labels"
        hash_path = labels_path if os.path.isfile(labels_path) else image_path
        with open(hash_path, "rb") as f:
            image_id = hashlib.sha256(f.read()).hexdigest()
    images[safe] = image_id
    by_id.setdefault(image_id, []).append(safe)

def resolve(ref):
    safe = ref.removeprefix("localhost/").replace("/", "_").replace(":", "_")
    if safe in images:
        return safe
    wanted = ref[7:] if ref.startswith("sha256:") else ref
    if len(wanted) < 12 or any(c not in "0123456789abcdefABCDEF" for c in wanted):
        return None
    matches = [image_id for image_id in by_id if image_id.startswith(wanted.lower())]
    if len(matches) != 1:
        return None
    return by_id[matches[0]][0]

in_use_ids = set()
for image_file in glob.glob(os.path.join(state_dir, "containers", "*.image")):
    try:
        with open(image_file) as f:
            stored = f.read().strip()
    except OSError:
        continue
    safe = resolve(stored)
    if safe is not None:
        in_use_ids.add(images[safe])

def unlink_record(candidate):
    os.unlink(os.path.join(state_dir, "images", candidate))
    for suffix in (".labels", ".id", ".ref"):
        side = os.path.join(state_dir, "images", candidate + suffix)
        if os.path.exists(side):
            os.unlink(side)

status = 0
for ref in refs:
    safe = resolve(ref)
    if safe is None:
        print(f"fake podman: no such image: {ref}", file=sys.stderr)
        status = 1
        continue
    image_id = images[safe]
    aliases = by_id.get(image_id, [])
    hash_ref = ref.startswith("sha256:") or (len(ref) >= 12 and all(c in "0123456789abcdefABCDEF" for c in ref))
    if hash_ref and len(aliases) > 1:
        # Real podman refuses ID removal while multiple tags remain.
        print(f"fake podman: unable to delete image {ref}: image is referred to in multiple tags", file=sys.stderr)
        status = 125
        continue
    if not hash_ref and len(aliases) > 1:
        # Untagging one of several names never touches containers.
        unlink_record(safe)
        by_id[image_id].remove(safe)
        del images[safe]
        continue
    if image_id in in_use_ids:
        print(f"fake podman: image {ref} is used by a container", file=sys.stderr)
        status = 2
        continue
    unlink_record(safe)
    by_id[image_id].remove(safe)
    del images[safe]
sys.exit(status)
